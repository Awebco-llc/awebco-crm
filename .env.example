# NEXT_PUBLIC_SUPPORT_TICKETS_EMAIL: Email address shown on the Support Tickets board.
NEXT_PUBLIC_SUPPORT_TICKETS_EMAIL="tickets@awebco.com"

.
# Firebase Web Config (client-side).
# Note: Firebase "apiKey" is not a secret, but keeping config in env makes it easier
# to swap projects per environment and avoids committing project details.
NEXT_PUBLIC_FIREBASE_PROJECT_ID="YOUR_FIREBASE_PROJECT_ID"
NEXT_PUBLIC_FIREBASE_APP_ID="YOUR_FIREBASE_APP_ID"
NEXT_PUBLIC_FIREBASE_API_KEY="YOUR_FIREBASE_API_KEY"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="YOUR_FIREBASE_AUTH_DOMAIN"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="YOUR_FIREBASE_STORAGE_BUCKET"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="YOUR_FIREBASE_MESSAGING_SENDER_ID"
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=""

# App-specific Firestore database id used by this app.
NEXT_PUBLIC_FIRESTORE_DATABASE_ID="YOUR_FIRESTORE_DATABASE_ID"

# ── Google Sheets Sync (SEO board → Google Sheets) ────────────────────────────
# These are SERVER-SIDE ONLY — never use NEXT_PUBLIC_ prefix here.
#
# Setup steps (one-time, ~5 minutes):
#   1. Go to console.cloud.google.com → APIs & Services → Enable "Google Sheets API"
#   2. IAM & Admin → Service Accounts → Create service account → create JSON key → Download
#   3. Open your Google Sheet → Share → paste the service account email → set to Editor
#   4. Fill in the three vars below and restart the dev server.
#
GOOGLE_SERVICE_ACCOUNT_EMAIL="your-service-account@your-project.iam.gserviceaccount.com"
# Paste the private_key value from the downloaded JSON. Keep the -----BEGIN/END----- lines.
# In .env, literal \n characters work fine — no need to escape further.
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
# The ID from your Google Sheet URL: docs.google.com/spreadsheets/d/THIS_PART/edit
GOOGLE_SHEETS_SPREADSHEET_ID="your-spreadsheet-id"

# ── Security & API Secrets ────────────────────────────────────────────────
# Used to secure the support ticket webhook (e.g. ?secret=YOUR_SECRET)
WEBHOOK_SECRET="your-secure-random-string-here"

# Used to secure the frontend -> backend API routes (like Sheets sync)
# Note: Since this is used in the browser, it is prefixed with NEXT_PUBLIC_
NEXT_PUBLIC_API_SECRET="another-secure-random-string-here"

# ── Mailgun Config (Email Notifications) ──────────────────────────────────────
# Your Mailgun Private API Key (starts with key- or api:key-)
MAILGUN_API_KEY="your-mailgun-private-api-key"
# Your verified domain in Mailgun (e.g. mg.yourdomain.com)
MAILGUN_DOMAIN="your-mailgun-verified-domain"
# Sender email address (e.g. CRM Notifications <noreply@yourdomain.com>)
MAILGUN_FROM_EMAIL="CRM Notifications <noreply@yourdomain.com>"
# Mailgun Host (defaults to api.mailgun.net, use api.eu.mailgun.net for EU region)
MAILGUN_HOST="api.mailgun.net"
